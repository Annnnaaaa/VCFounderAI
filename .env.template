# VC Brain — fill these in and share with all lanes (copy to .env in each lane's dir)
# ── Supabase (create project at https://supabase.com → New project) ─────────
SUPABASE_URL=            # Project Settings → API → Project URL
SUPABASE_SERVICE_KEY=    # Project Settings → API → service_role key (NOT anon)

# ── OpenAI (https://platform.openai.com/api-keys) ───────────────────────────
OPENAI_API_KEY=

# ── Tavily (https://app.tavily.com → API keys) ──────────────────────────────
TAVILY_API_KEY=

# ── GitHub PAT (https://github.com/settings/tokens → classic, public_repo + read:user scopes) ──
GITHUB_PAT=

# ── Lane 1 API base URL (set once Lane 1 shares it, ~T+1:00) ────────────────
SPINE_URL=http://localhost:8000
